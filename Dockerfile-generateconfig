FROM ghcr.io/anyproto/any-sync-tools:latest

WORKDIR /code

RUN apt update && \ 
    apt install -y python3 python3-pip && \
    pip3 install --no-cache-dir pyyaml

ENTRYPOINT sh -c \
    "if [ -f /code/etc/client.yml ] && [ ! -f /code/docker-generateconfig/ids.yml ]; then \
		python3 /code/docker-generateconfig/persistentAccount.py && \
        any-sync-network create --auto --c /code/docker-generateconfig/defaultTemplate.yml && \
        python3 /code/docker-generateconfig/persistentAccount.py; \
    else \
        any-sync-network create --auto --c /code/docker-generateconfig/defaultTemplate.yml && \
        python3 /code/docker-generateconfig/persistentAccount.py; \
    fi"
